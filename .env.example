# Copy this file to ".env" and fill in real values.
#
# Admin sign-in for the CRM at /admin is handled by Clerk (see
# https://dashboard.clerk.com -> your app -> API Keys). Restrict sign-up to
# invited admins in Clerk's dashboard under User & Authentication ->
# Restrictions, then invite specific people from the Users tab.
# VITE_CLERK_PUBLISHABLE_KEY is exposed to the client bundle at build time
# (that's expected for Clerk's publishable key). CLERK_SECRET_KEY must stay
# server-side only — never prefix it with VITE_.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs — point these to your own app routes so Clerk never
# redirects to its hosted pages. For this CRM the admin panel is at /admin.
VITE_CLERK_SIGN_IN_URL=/admin
VITE_CLERK_SIGN_UP_URL=/admin
VITE_CLERK_AFTER_SIGN_IN_URL=/admin
VITE_CLERK_AFTER_SIGN_UP_URL=/admin

# Your site's full URL. Used by the Netlify Functions to construct the
# redirect URL in Clerk invitation emails so users land back on your /admin
# after accepting an invite. In production Netlify sets process.env.URL
# automatically; this is only needed for local development.
SITE_URL=http://localhost:5173

# Cloudflare Worker that stores/serves resume files in R2 (see /worker).
# Leave blank to disable resume upload/preview entirely.
# VITE_RESUME_ACCESS_TOKEN ships in the client bundle (unavoidable for a
# static site) — it keeps resumes unlisted, not truly private. See worker/README.md.
VITE_RESUME_WORKER_URL=
VITE_RESUME_ACCESS_TOKEN=

# Supabase project used by the Netlify Functions in /netlify/functions to
# read/write job descriptions, applications & notes so every device sees the
# same CRM data. These are read server-side only (no VITE_ prefix) — never
# expose the service_role key to the client bundle. Get both from the
# Supabase dashboard: Project Settings -> API. Also set these two in
# Netlify's Site settings -> Environment variables for the deployed site.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Realtime (WebSocket) — these are exposed to the browser bundle so
# the client can subscribe to live database changes. The anon key is safe to
# expose; it only has the permissions defined by your RLS policies. Get the
# anon key from Supabase dashboard: Project Settings -> API -> Project API keys.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
