# Copy this file to ".env" and set your own default admin credentials for the
# CRM at /admin. Variables prefixed with VITE_ are exposed to the client bundle
# at build time, so do NOT put real secrets here.
#
# The admin can still change both values at runtime from the CRM's "Settings"
# tab (stored in the browser, overriding these defaults).
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123

# Cloudflare Worker that stores/serves resume files in R2 (see /worker).
# Leave blank to disable resume upload/preview entirely.
# VITE_RESUME_ACCESS_TOKEN ships in the client bundle (unavoidable for a
# static site) — it keeps resumes unlisted, not truly private. See worker/README.md.
VITE_RESUME_WORKER_URL=
VITE_RESUME_ACCESS_TOKEN=
